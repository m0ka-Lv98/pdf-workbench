QMainWindow#mainWindow {
  background: #f8f9fb;
  color: #20242a;
}

QMenuBar,
QMenuBar::item,
QMenu,
QStatusBar#mainStatusBar,
QWidget#centralContainer,
QWidget#mainStack,
QWidget#pdfView,
QWidget#pdfContent {
  background: transparent;
  color: #20242a;
}

QMenuBar {
  background: #f8f9fb;
  border-bottom: 1px solid #d9dde3;
}

QMenuBar::item {
  padding: 6px 8px;
  margin: 2px;
  border-radius: 4px;
}

QMenuBar::item:selected,
QMenu::item:selected {
  background: #f1f3f6;
}

QMenu {
  background: #ffffff;
  border: 1px solid #d9dde3;
  padding: 6px;
}

QMenu::item {
  padding: 7px 12px;
  border-radius: 4px;
}

QWidget#mainToolbar {
  background: #ffffff;
  border-bottom: 1px solid #d9dde3;
}

QWidget#documentToolbar {
  background: transparent;
}

QWidget#searchToolbar {
  background: transparent;
}

QWidget#sourceChangeBanner {
  background: #fff7e8;
  border-top: 1px solid #f3d08b;
  border-bottom: 1px solid #f3d08b;
}

QWidget#sourceChangeBanner[sourceStatus="modified"] {
  background: #fff7e8;
}

QWidget#sourceChangeBanner[sourceStatus="missing"],
QWidget#sourceChangeBanner[sourceStatus="unreadable"] {
  background: #fff4ef;
  border-top: 1px solid #efb794;
  border-bottom: 1px solid #efb794;
}

QWidget#sourceChangeBanner QLabel#sourceChangeBannerMessage {
  color: #5a3f16;
  background: transparent;
}

QWidget#sourceChangeBanner QPushButton {
  min-height: 32px;
  border: 1px solid #d9dde3;
  border-radius: 7px;
  background: #ffffff;
  color: #20242a;
  padding: 0 12px;
}

QWidget#sourceChangeBanner QPushButton:hover {
  background: #f1f3f6;
}

QWidget#sourceChangeBanner QPushButton:pressed {
  background: #e5e9ef;
}

QWidget#searchSurface {
  background: transparent;
  border: none;
  border-radius: 0;
}

QWidget#searchInputSurface {
  background: transparent;
  border: none;
  border-radius: 0;
}

QWidget#searchInputSurface[focused="true"] {
  border: none;
}

QWidget#toolbarSeparator {
  background: #d9dde3;
  min-width: 1px;
  max-width: 1px;
  min-height: 18px;
  max-height: 22px;
  margin: 0 8px;
}

QWidget#documentToolbar QPushButton,
QWidget#documentToolbar QToolButton,
QWidget#searchBar QToolButton,
QWidget#emptyState QPushButton {
  min-height: 34px;
  border: 1px solid transparent;
  border-radius: 7px;
  background: transparent;
  color: #20242a;
  padding: 0 10px;
  font-size: 13px;
}

QWidget#documentToolbar QPushButton#openPdfButton {
  min-height: 36px;
  min-width: 118px;
  max-width: 128px;
  padding: 0 16px;
  background: #2563eb;
  color: #ffffff;
  font-weight: 600;
}

QWidget#documentToolbar QToolButton#zoomOutButton,
QWidget#documentToolbar QToolButton#zoomInButton {
  min-width: 34px;
  max-width: 34px;
  border: 1px solid #d9dde3;
  border-radius: 17px;
  background: #ffffff;
}

QWidget#documentToolbar QToolButton,
QWidget#searchBar QToolButton {
  min-width: 34px;
  max-width: 34px;
  min-height: 34px;
  max-height: 34px;
  padding: 0;
}

QWidget#searchInputSurface QToolButton#clearSearchInputButton {
  min-width: 26px;
  max-width: 26px;
  min-height: 26px;
  max-height: 26px;
  border: none;
  border-radius: 6px;
  background: transparent;
  padding: 0;
}

QWidget#documentToolbar QPushButton:hover,
QWidget#documentToolbar QToolButton:hover,
QWidget#searchBar QToolButton:hover,
QWidget#emptyState QPushButton:hover {
  background: #f1f3f6;
}

QWidget#documentToolbar QPushButton#openPdfButton:hover,
QWidget#emptyState QPushButton[variant="primary"]:hover {
  background: #1d4ed8;
}

QWidget#documentToolbar QPushButton:pressed,
QWidget#documentToolbar QToolButton:pressed,
QWidget#searchBar QToolButton:pressed,
QWidget#emptyState QPushButton:pressed {
  background: #e5e9ef;
}

QWidget#documentToolbar QPushButton#openPdfButton:pressed,
QWidget#emptyState QPushButton[variant="primary"]:pressed {
  background: #1e40af;
}

QWidget#documentToolbar QPushButton:disabled,
QWidget#documentToolbar QToolButton:disabled,
QWidget#documentToolbar QComboBox:disabled,
QWidget#documentToolbar QSpinBox:disabled,
QWidget#searchBar QLineEdit:disabled,
QWidget#searchBar QToolButton:disabled,
QWidget#emptyState QPushButton:disabled {
  color: #a4aab4;
  background: transparent;
}

QWidget#documentToolbar QComboBox,
QWidget#documentToolbar QSpinBox,
QWidget#searchBar QLineEdit {
  min-height: 34px;
  border: 1px solid #d9dde3;
  border-radius: 7px;
  background: #ffffff;
  color: #20242a;
  padding: 0 4px;
  font-size: 13px;
}

QWidget#documentToolbar QSpinBox#pageNumberInput {
  min-width: 56px;
  max-width: 56px;
  padding: 0 2px;
}

QWidget#documentToolbar QComboBox#zoomControl {
  padding-left: 6px;
  padding-right: 22px;
}

QWidget#documentToolbar QComboBox::drop-down {
  width: 22px;
  border: none;
  background: transparent;
}

QWidget#documentToolbar QComboBox::down-arrow {
  image: none;
  width: 0;
  height: 0;
}

QWidget#documentToolbar QComboBox QAbstractItemView {
  background: #ffffff;
  color: #20242a;
  border: 1px solid #d9dde3;
  selection-background-color: #f1f3f6;
  selection-color: #20242a;
  padding: 4px;
  outline: none;
}

QWidget#documentToolbar QSpinBox QLineEdit#pageNumberEditor,
QWidget#documentToolbar QComboBox QLineEdit#zoomControlEditor {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
}

QWidget#documentToolbar QSpinBox QLineEdit#pageNumberEditor {
  qproperty-alignment: AlignCenter;
}

QWidget#documentToolbar QComboBox QLineEdit#zoomControlEditor {
  qproperty-alignment: AlignCenter;
}

QWidget#searchBar QLineEdit#searchInput {
  min-height: 28px;
  max-height: 28px;
  border: none;
  border-radius: 0;
  background: transparent;
  padding: 0;
}

QWidget#documentToolbar QComboBox:hover,
QWidget#documentToolbar QSpinBox:hover,
QWidget#searchBar QLineEdit:hover,
QWidget#emptyState QPushButton[variant="recent"]:hover {
  border-color: #c1c8d1;
}

QWidget#searchInputSurface QToolButton#clearSearchInputButton:hover {
  background: rgba(32, 36, 42, 0.08);
}

QWidget#documentToolbar QPushButton:focus,
QWidget#documentToolbar QToolButton:focus,
QWidget#documentToolbar QComboBox:focus,
QWidget#documentToolbar QSpinBox:focus,
QWidget#searchBar QToolButton:focus,
QWidget#emptyState QPushButton:focus {
  border: 1px solid #2563eb;
}

QWidget#searchInputSurface QToolButton#clearSearchInputButton:pressed {
  background: rgba(32, 36, 42, 0.14);
}

QWidget#searchBar QLineEdit#searchInput:focus {
  border: none;
}

QWidget#documentToolbar QLabel,
QWidget#searchBar QLabel,
QStatusBar#mainStatusBar QLabel {
  background: transparent;
  border: none;
}

QLabel#searchIcon {
  margin: 0;
  padding: 0;
}

QLabel#pageTotalLabel,
QLabel#searchProgressLabel,
QLabel#statusSummaryLabel,
QLabel#statusMessageLabel,
QLabel#emptyStateSubtitle,
QLabel#emptyStateRecentHint,
QLabel#emptyStateRecentMessage {
  color: #69707d;
}

QLabel#searchResultCounter {
  color: #20242a;
  font-weight: 600;
  min-width: 48px;
}

QLabel#statusStateIcon[error="true"],
QLabel#searchProgressLabel[error="true"] {
  color: #b42318;
}

QStatusBar#mainStatusBar {
  background: #ffffff;
  border-top: 1px solid #d9dde3;
  min-height: 28px;
}

QStatusBar#mainStatusBar::item {
  border: none;
}

QWidget#statusLeftContainer {
  background: transparent;
}

QWidget#statusRightContainer {
  background: transparent;
}

QDialog#recoveryDialog {
  background: #ffffff;
  color: #20242a;
  border: 1px solid #d9dde3;
  border-radius: 12px;
}

QDialog#recoveryDialog QLabel {
  color: #20242a;
  background: transparent;
}

QDialog#recoveryDialog QTreeWidget {
  background: #ffffff;
  color: #20242a;
  border: 1px solid #d9dde3;
  border-radius: 10px;
  alternate-background-color: #f8f9fb;
}

QDialog#recoveryDialog QTreeWidget::item {
  min-height: 28px;
}

QDialog#recoveryDialog QTreeWidget::item:selected {
  background: #f1f3f6;
  color: #20242a;
}

QDialog#recoveryDialog QHeaderView::section {
  background: #f3f5f8;
  color: #4b5565;
  border: none;
  border-right: 1px solid #e3e7ed;
  border-bottom: 1px solid #d9dde3;
  padding: 8px 10px;
  font-weight: 600;
}

QDialog#recoveryDialog QPushButton {
  min-height: 34px;
  border: 1px solid #d9dde3;
  border-radius: 8px;
  background: #ffffff;
  color: #20242a;
  padding: 0 14px;
}

QDialog#recoveryDialog QPushButton:hover {
  background: #f1f3f6;
}

QDialog#recoveryDialog QPushButton:pressed {
  background: #e5e9ef;
}

QDialog#recoveryDialog QPushButton:disabled {
  color: #a4aab4;
  background: #f3f5f8;
  border-color: #e3e7ed;
}

QDialog#recoveryDialog QTreeWidget::indicator {
  width: 16px;
  height: 16px;
  border: 1px solid #69707d;
  border-radius: 4px;
  background: #ffffff;
}

QDialog#recoveryDialog QTreeWidget::indicator:checked {
  border-color: #2563eb;
  background: #2563eb;
}

QTabWidget#documentTabs {
  background: #f7f8fa;
}

QTabWidget#documentTabs::pane {
  border: none;
  background: #f7f8fa;
  top: 0;
}

QTabBar#documentTabBar {
  background: #f7f8fa;
}

QTabBar#documentTabBar::tab {
  min-height: 38px;
  background: transparent;
  color: #69707d;
  padding: 0 14px;
  margin: 0;
  border: none;
  border-bottom: 2px solid transparent;
}

QTabBar#documentTabBar::tab:selected {
  background: #ffffff;
  color: #20242a;
  border-bottom-color: #2563eb;
  font-weight: 600;
}

QTabBar#documentTabBar::tab:hover:!selected {
  color: #20242a;
  background: rgba(32, 36, 42, 0.03);
}

QTabBar#documentTabBar QToolButton#tabCloseButton {
  background: transparent;
  border: none;
  border-radius: 6px;
  padding: 0;
  margin-right: 4px;
}

QTabBar#documentTabBar QToolButton#tabCloseButton:hover {
  background: rgba(32, 36, 42, 0.08);
}

QTabBar#documentTabBar QToolButton#tabCloseButton:pressed {
  background: rgba(32, 36, 42, 0.14);
}

QWidget#emptyState {
  background: transparent;
}

QWidget#emptyState QLabel#emptyStateTitle {
  font-size: 22px;
  font-weight: 650;
  color: #20242a;
}

QWidget#emptyState QLabel#emptyStateIcon {
  color: #69707d;
}

QWidget#emptyState QPushButton[variant="primary"] {
  background: #2563eb;
  color: #ffffff;
  padding: 0 18px;
  font-weight: 600;
}

QWidget#emptyState QPushButton[variant="recent"] {
  text-align: left;
  padding: 0 12px;
  border: 1px solid #d9dde3;
  background: #ffffff;
}

QScrollArea#pdfScrollArea,
QWidget#pdfCanvas {
  border: none;
  background: #eef0f3;
}

QFrame#pageCard {
  background: #ffffff;
  border: 1px solid #d9dde3;
  border-radius: 2px;
}

QFrame#pageCard[renderState="not_requested"],
QFrame#pageCard[renderState="queued"],
QFrame#pageCard[renderState="rendering"] {
  color: #69707d;
}

QFrame#pageCard[renderState="error"] {
  background: #fff4f4;
  border-color: #f97066;
  color: #b42318;
}

QLabel#pdfStatusLabel[renderState="error"] {
  color: #b42318;
}
